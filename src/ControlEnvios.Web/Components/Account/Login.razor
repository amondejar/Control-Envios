@page "/login"
@layout LoginLayout
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using ControlEnvios.Application.Autenticacion
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@inject IAuthService AuthService
@inject NavigationManager Nav

<PageTitle>Acceso — Control de Envíos</PageTitle>

<MudPaper Elevation="6" Class="pa-8" Style="width:100%;max-width:420px;border-radius:16px;">
    <div class="d-flex justify-center mb-2">
        <MudImage Src="images/logo.jpg" Alt="Derivados Cítricos" Height="64" />
    </div>
    <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-1">Control de Envíos</MudText>
    <MudText Typo="Typo.body2" Align="Align.Center" Class="mud-text-secondary mb-6">Acceso de proveedores y gestión</MudText>

    <EditForm Model="Input" FormName="login" OnValidSubmit="Entrar">
        <DataAnnotationsValidator />

        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Class="mb-4">@_error</MudAlert>
        }

        <label class="login-label" for="usuario">Usuario / Cód. proveedor</label>
        <InputText id="usuario" @bind-Value="Input.Usuario" class="login-input" autocomplete="username" />
        <ValidationMessage For="() => Input.Usuario" />

        <label class="login-label" for="password">Contraseña</label>
        <InputText id="password" type="password" @bind-Value="Input.Password" class="login-input" autocomplete="current-password" />
        <ValidationMessage For="() => Input.Password" />

        <button type="submit" class="login-button">Entrar</button>
    </EditForm>
</MudPaper>

@code {
    [CascadingParameter] private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm] private LoginModel Input { get; set; } = new();

    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }

    private string? _error;

    private async Task Entrar()
    {
        ResultadoLogin resultado;
        try
        {
            resultado = await AuthService.AutenticarAsync(Input.Usuario, Input.Password);
        }
        catch (Exception)
        {
            // Sin BD configurada u otro fallo: mensaje neutro (no se filtran detalles internos).
            _error = "No se pudo validar el acceso. Inténtelo de nuevo más tarde.";
            return;
        }

        if (!resultado.Exito)
        {
            _error = resultado.Motivo ?? ResultadoLogin.MensajeCredencialesInvalidas;
            return;
        }

        var claims = new List<Claim>
        {
            new(ClaimTypes.Name, resultado.Identificador!),
            new(ClaimTypes.GivenName, resultado.Nombre ?? resultado.Identificador!),
            new(ClaimTypes.Role, resultado.Rol!.Value.ToString()),
        };
        var identidad = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
        await HttpContext.SignInAsync(CookieAuthenticationDefaults.AuthenticationScheme, new ClaimsPrincipal(identidad));

        Nav.NavigateTo(string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl);
    }

    public sealed class LoginModel
    {
        [Required(ErrorMessage = "Introduzca el usuario.")]
        public string Usuario { get; set; } = string.Empty;

        [Required(ErrorMessage = "Introduzca la contraseña.")]
        public string Password { get; set; } = string.Empty;
    }
}
