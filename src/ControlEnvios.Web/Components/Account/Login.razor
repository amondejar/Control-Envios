@page "/login"
@layout LoginLayout

<PageTitle>Acceso — Control de Envíos</PageTitle>

<MudPaper Elevation="6" Class="pa-8" Style="width:100%;max-width:420px;border-radius:18px;">
    <div class="d-flex justify-center mb-2">
        <MudImage Src="images/logo.jpg" Alt="Derivados Cítricos" Height="64" />
    </div>
    <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-1">Control de Envíos</MudText>
    <MudText Typo="Typo.body2" Align="Align.Center" Class="mud-text-secondary mb-6">Acceso de proveedores y gestión</MudText>

    @if (Error is not null)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Class="mb-4">@MensajeError</MudAlert>
    }

    @* Formulario nativo: postea al endpoint /account/login, que valida y firma la cookie. *@
    <form method="post" action="/account/login" data-enhance="false">
        <input type="hidden" name="returnUrl" value="@ReturnUrl" />

        <label class="login-label" for="usuario">Usuario / Cód. proveedor</label>
        <input id="usuario" name="usuario" class="login-input" autocomplete="username" required />

        <label class="login-label" for="password">Contraseña</label>
        <input id="password" name="password" type="password" class="login-input" autocomplete="current-password" required />

        <button type="submit" class="login-button">Entrar</button>
    </form>
</MudPaper>

@code {
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] private string? Error { get; set; }

    private string MensajeError => Error == "2"
        ? "No se pudo validar el acceso. Inténtelo de nuevo más tarde."
        : "Usuario o contraseña incorrecta.";
}
