@using ControlEnvios.Domain.Entities

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="Model">
            <MudSelect T="string" @bind-Value="Model.CodigoArticulo" Label="Artículo" Variant="Variant.Outlined"
                       Required="true" RequiredError="Seleccione un artículo." Class="mb-3">
                @foreach (var a in Articulos)
                {
                    <MudSelectItem Value="@a.Codigo">@a.Descripcion</MudSelectItem>
                }
            </MudSelect>

            <MudDatePicker @bind-Date="Model.FechaEnvio" Label="Fecha de envío" Variant="Variant.Outlined"
                           Required="true" RequiredError="Indique la fecha." Class="mb-3" />

            <MudTextField @bind-Value="Model.HoraEnvio" Label="Hora (HH:mm)" Variant="Variant.Outlined"
                          Required="true" Validation="@((Func<string?, string?>)ValidarHora)" Class="mb-3" />

            <MudNumericField @bind-Value="Model.KilosEnviados" Label="Kilos enviados" Variant="Variant.Outlined"
                             Required="true" Min="0" Class="mb-3" />

            <MudTextField @bind-Value="Model.Matricula" Label="Matrícula" Variant="Variant.Outlined"
                          Required="true" Validation="@((Func<string?, string?>)ValidarMatricula)" Class="mb-3" />

            <MudTextField @bind-Value="Model.Observaciones" Label="Observaciones" Variant="Variant.Outlined"
                          Lines="2" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Guardar">Guardar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public EnvioFormModel Model { get; set; } = new();
    [Parameter] public IReadOnlyList<Articulo> Articulos { get; set; } = [];

    private MudForm _form = default!;

    private static string? ValidarHora(string? hora) =>
        TimeOnly.TryParse(hora, out _) ? null : "Hora no válida (HH:mm).";

    private static string? ValidarMatricula(string? matricula) =>
        string.IsNullOrEmpty(matricula) || System.Text.RegularExpressions.Regex.IsMatch(matricula, "^[A-Za-z0-9 ]*$")
            ? null
            : "La matrícula no debe contener guiones ni símbolos.";

    private async Task Guardar()
    {
        await _form.ValidateAsync();
        if (_form.IsValid)
        {
            MudDialog.Close(DialogResult.Ok(Model));
        }
    }

    private void Cancelar() => MudDialog.Cancel();
}
