<MudPaper Class="pa-3 d-flex align-center" Elevation="2" Style="gap:0.75rem;">
    <MudIcon Icon="@Icono" Color="@Color" Size="Size.Large" />
    <div>
        <MudText Typo="Typo.caption" Class="mud-text-secondary">@Titulo</MudText>
        <MudText Typo="Typo.h6">@Valor</MudText>
    </div>
</MudPaper>

@code {
    [Parameter] public string Titulo { get; set; } = string.Empty;
    [Parameter] public string Valor { get; set; } = string.Empty;
    [Parameter] public string Icono { get; set; } = string.Empty;
    [Parameter] public Color Color { get; set; } = Color.Default;
}
