@page "/gestor"
@attribute [Authorize(Roles = "Gestor")]
@using ControlEnvios.Application.Abstractions.Persistence
@using ControlEnvios.Application.Consultas
@using ControlEnvios.Domain.Entities
@inject IProveedorRepository ProveedorRepo
@inject IArticuloRepository ArticuloRepo
@inject IConsultaEnviosService Consultas
@inject ISnackbar Snackbar

<PageTitle>Gestión de envíos</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Gestión de envíos</MudText>

<MudPaper Class="pa-4 mb-4" Elevation="2">
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudDatePicker @bind-Date="_fechaInicio" Label="Fecha inicio" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudDatePicker @bind-Date="_fechaFin" Label="Fecha fin" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudSelect T="string" @bind-Value="_proveedor" Label="Proveedor" Variant="Variant.Outlined" Clearable="true">
                @foreach (var p in _proveedores)
                {
                    <MudSelectItem Value="@p.Codigo">@p.Nombre</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudSelect T="string" @bind-Value="_articulo" Label="Artículo" Variant="Variant.Outlined" Clearable="true">
                @foreach (var a in _articulos)
                {
                    <MudSelectItem Value="@a.Codigo">@a.Descripcion</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    </MudGrid>
    <div class="d-flex justify-end mt-3">
        <MudButton StartIcon="@Icons.Material.Filled.Search" Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="Buscar" Disabled="_buscando">Buscar</MudButton>
    </div>
</MudPaper>

<MudDataGrid T="ConsultaEnvio" Items="_resultados" Loading="_buscando" Dense="true" Hover="true" Elevation="2"
             Filterable="true" SortMode="SortMode.Multiple">
    <Columns>
        <PropertyColumn Property="x => x.FechaEnvio" Title="Fecha" />
        <PropertyColumn Property="x => x.HoraEnvio" Title="Hora" />
        <PropertyColumn Property="x => x.NombreProveedor" Title="Proveedor" />
        <PropertyColumn Property="x => x.NombreArticulo" Title="Artículo" />
        <PropertyColumn Property="x => x.Matricula" Title="Matrícula" />
        <PropertyColumn Property="x => x.KilosEnviados" Title="Kilos" Format="N0" />
        <PropertyColumn Property="x => x.PesoBascula" Title="Neto báscula" Format="N0" />
        <PropertyColumn Property="x => x.Observaciones" Title="Observaciones" />
    </Columns>
    <NoRecordsContent>
        <MudText Class="pa-4 mud-text-secondary">Sin resultados para los filtros seleccionados.</MudText>
    </NoRecordsContent>
</MudDataGrid>

@code {
    private DateTime? _fechaInicio = DateTime.Today.AddDays(-7);
    private DateTime? _fechaFin = DateTime.Today;
    private string? _proveedor;
    private string? _articulo;
    private bool _buscando;

    private IReadOnlyList<Proveedor> _proveedores = [];
    private IReadOnlyList<Articulo> _articulos = [];
    private IReadOnlyList<ConsultaEnvio> _resultados = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _proveedores = await ProveedorRepo.GetSeleccionablesAsync();
            _articulos = await ArticuloRepo.GetActivosWebAsync();
        }
        catch (Exception)
        {
            Snackbar.Add("No hay conexión con la base de datos configurada.", Severity.Warning);
        }
    }

    private async Task Buscar()
    {
        if (_fechaInicio is null || _fechaFin is null)
        {
            Snackbar.Add("Indique el rango de fechas.", Severity.Warning);
            return;
        }

        _buscando = true;
        try
        {
            _resultados = await Consultas.PorFechasAsync(
                DateOnly.FromDateTime(_fechaInicio.Value),
                DateOnly.FromDateTime(_fechaFin.Value),
                _proveedor,
                _articulo);

            if (_resultados.Count == 0)
            {
                Snackbar.Add("Sin resultados para los filtros seleccionados.", Severity.Info);
            }
        }
        catch (Exception)
        {
            _resultados = [];
            Snackbar.Add("No se pudo realizar la consulta.", Severity.Error);
        }
        finally
        {
            _buscando = false;
        }
    }
}
