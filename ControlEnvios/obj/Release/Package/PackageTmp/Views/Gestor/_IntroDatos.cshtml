@model ControlEnvios.Models.ModelGestor
@using ControlEnvios.Resources
@using Newtonsoft.Json;

<link href="~/Content/bootstrap-datetimepicker.css" rel="stylesheet" />

<div>
    <div class="row text-center">
        <h3 class="expense-title col-sm-5 col-sm-offset-4">@Gestor.IntroDates</h3>
    </div>
</div>

<div class="row">
        @using (Html.BeginForm("Create", "Gestor", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", role = "form", @id = "formGestor" }))
        {
        @Html.AntiForgeryToken()
    <div class="form-horizontal text-center">
        <div class="form-group">
            <div class="col-sm-5 col-sm-offset-4">
                @Html.LabelFor(m => m.DtFechaInicio)
                <div class="input-group date datetimepicker">
                    @Html.TextBoxFor(m => m.DtFechaInicio, new { @class = "form-control", @readonly = "readonly", @Value = DateTime.Now.ToShortDateString() })
                    @Html.HiddenFor(m => m.DtFechaInicio)
                    <span class="input-group-addon">
                        <span class="glyphicon glyphicon-calendar"></span>
                    </span>
                </div>
            </div>
            @Html.ValidationMessageFor(m => m.DtFechaInicio, "", new { @class = "text-danger", @readonly = "readonly" })
        </div>
        <div class="form-group">
            <div class="col-sm-5 col-sm-offset-4">
                @Html.LabelFor(m => m.DtFechaFin)
                <div class="input-group date datetimepicker">
                    @Html.TextBoxFor(m => m.DtFechaFin, new { @class = "form-control", @readonly = "readonly", @Value = DateTime.Now.ToShortDateString() })
                    @Html.HiddenFor(m => m.DtFechaFin)
                    <span class="input-group-addon">
                        <span class="glyphicon glyphicon-calendar"></span>
                    </span>
                </div>
            </div>
            @Html.ValidationMessageFor(m => m.DtFechaFin, "", new { @class = "text-danger", @readonly = "readonly" })

        </div>
        <div class="form-group">
            <hr />
        </div>
        <div class="form-group">
            <div class="col-sm-5 col-sm-offset-4">
                @Html.LabelFor(Model => Model.Proveedores)
                @Html.DropDownListFor(Model => Model.Proveedor, new SelectList(Model.Proveedores, "Value", "Text"), new { @class = "form-control", @id = "CodProveedor" })
                @Html.HiddenFor(Model => Model.Proveedor)
                @Html.ValidationMessageFor(Model => Model.Proveedor, "", new { @class = "text-danger" })
            </div>
            <hr />
            <div class="col-sm-5 col-sm-offset-4">
                @Html.LabelFor(Model => Model.Articulos)
                @Html.DropDownListFor(Model => Model.Articulo, new SelectList(Model.Articulos, "Value", "Text"), new { @class = "form-control", @id = "CodArticulo" })
                @Html.HiddenFor(Model => Model.Articulo)
                @Html.ValidationMessageFor(Model => Model.Articulo, "", new { @class = "text-danger" })
            </div>
          </div>
    </div>
        <hr />
    <div class="row text-center mg-25">
        <div class="form-horizontal form-group">
            <!-- Button -->
            <div class="col-sm-12 controls log-sec">
                <input type="submit"  value="Ver Envios"  class="btn btn-success btn-paysheetreviewrequest" />
            </div>
        </div>
    </div>   
       <div class="row text-center mg-25">
           <div class="form-horizontal form-group">
               <div class="col-sm-12 controls log-sec">
                   <a class="btn btn-success btn-paysheetreviewrequest" href="@Url.Action("Index", "Home")">Volver Atras</a>
               </div>
           </div>
      </div>
        }
    
</div>
@Scripts.Render("~/bundles/jqueryval")
<script type="text/javascript">

    $('.datetimepicker').datetimepicker({
        format: 'DD/MM/YYYY HH:mm',
        ignoreReadonly: true,
        defaultDate: moment(),
        locale: localStorage.getItem("CurrentCulture"),
        keepOpen: true
    }).on('dp.change', function (ev) {
        $(this).datetimepicker('hide');
    });
</script>
