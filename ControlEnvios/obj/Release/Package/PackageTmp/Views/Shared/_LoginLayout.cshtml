
@{
    Layout = null;
    string info = System.Globalization.CultureInfo.CurrentCulture.Name;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <script src="http://cdnjs.cloudflare.com/ajax/libs/jquery/2.1.1/jquery.min.js"></script>
    <script src="http://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.0.2/js/toastr.min.js"></script>
    <link rel="stylesheet" href="http://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css"/>

    <title>@ViewBag.Title</title>
    @Styles.Render("~/Content/logincss")
    <style type="text/css">
        .footer {
            position: fixed;
            right: 0;
            bottom: 0;
            left: 0;
            padding: 1rem;
            background-color: #efefef;
            text-align: center;
        }

        .footer-dark {
            background-color: #212429;
            color: white;
        }

        .footer img {
            max-width: 100px;
            margin: 0 auto;
        }
    </style>
    @Scripts.Render("~/bundles/modernizr")
</head>
<body class="login-page bg-home">
    <!-- Page Content -->
    <div class="container">
        <!-- Set Culture infor into hidden field-->
        <input type="hidden" value="@info" id="CurrentCulture" />
        <div class="row">
            <div class="text-center">
                @*<a href="@Url.Action("Index", "Home")">
                    <img src="@Url.Content("~/images/logo.jpg")" class="header-logo" data-displaymode="Original" alt="Logo-juver" title="logo" />
                </a>*@
            </div>
        </div>
        <div class="content">
            <div class="header-clear"></div>
            <div class="row">
                <div class="text-center col-md-12">
                    <h1>Control de Envios</h1>
                </div>
            </div>
            <div class="container container-mb-15">
                @RenderBody()
            </div>
            <!-- Footer -->
            <div class="container-fullscreen footer  footer-light">
                <div class="half-bottom text-center">
                    <p class="text-center">
                        <img src="@Url.Content("~/images/logo_footer.png")" data-displaymode="Original" alt="logo" title="logo">
                    </p>
                </div>
                <div class="decoration"></div>
                <div class="small-text no-bottom text-center">©@DateTime.Now.Year  Derechos de autor.</div>
            </div>
        </div>

    </div>
    <!-- Modal Dialog -->
    <div id="alertDiv" class="modal fade" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title" id="alertModalTitle"></h4>
                </div>
                <div class="modal-body" id="alertModalbody">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-dismiss="modal" id="alertModalCloseButton"></button>
                </div>
            </div>
        </div>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    <script type="text/javascript">
        localStorage.setItem('CurrentCulture', $("#CurrentCulture").val());
    </script>
    @RenderSection("scripts", required: false)
    <script src="@Url.Content("~/Scripts/Application/Login.js")"></script>
</body>
</html>