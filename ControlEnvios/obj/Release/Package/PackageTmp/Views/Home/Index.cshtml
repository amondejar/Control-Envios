@model List<ControlEnvios.Models.ModelModulo> 
@{
    Layout = "~/Views/Shared/_Layout.cshtml";

}

<!DOCTYPE html>

<div class="header-clear"></div>
<div class="text-center header-home">
    <h1>Gestión de Modulos</h1>
</div>
<div class="home-page">
    <div class="row">
        @if (Model != null && Model.Count > 0)
        {
            <ul class="menu-circles">
                
                @foreach (var item in Model)
                {                                   
                    <li>
                        <div class="circle bg-@item.bgname.ToString()" id="div_@item.IdModulo.ToString()">
                            <div class="countbadge"></div>
                            <a href="@Url.Action(item.Acction, item.Controller,new {@id=(string)ViewBag.CodProveedor })">
                                <img src="@Url.Content("~/Iconos/")@item.Icono.ToString()" />
                                <em>
                                    @item.Nombre.ToString()
                                </em>
                            </a>
                        </div>
                    </li>  
                }
            </ul>
          }
          else
          {
              <div>
                 <h2>No hay modulos que mostrar</h2>
              </div>
          }
        
                    

    </div>
    <div class="clear"></div>
</div>
@section Scripts {
    <script src="@Url.Content("~/Scripts/Application/Home.js")"></script>
}