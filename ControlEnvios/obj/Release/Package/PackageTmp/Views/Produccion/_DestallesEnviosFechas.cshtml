@model List<ControlEnvios.Models.ModeloEnvio>
@using ControlEnvios.Models
@using ControlEnvios.Resources


<div>
    <div class="row text-center header-holidayleave">
        <h3 class="sitetitle mt-0">@Envios.TituloEnvioMercancia</h3> 
    </div>
    <!------->
    @if (Model.Count > 0)
    {
        decimal acumulador = 0;
        <div class="row text-center mt-30">
            <section id="no-more-tables">
                <table class="table table-responsive table-hover" id="tableVerEnvios">
                    <thead>
                        <tr>
                            <th align="left">@Envios.CodProvEnvio</th>
                            <th align="left">@Envios.Proveedor</th>
                            <th>@Envios.MatriculaEnvio</th>
                            <th>@Envios.ArticuloEnvio</th>
                            <th>@Envios.FechaEnvio</th>
                            <th>@Envios.HoraEnvio</th>
                            <th>@Envios.KilosEnvio</th>
                            <th>@Envios.PesadaNeto</th>
                            <th>@Gestor.BalsaG</th>
                            <th>@Gestor.BalsaP</th>
                            <th>Observaciones</th>
                            @*<th>Acciones</th>*@
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var Env in Model)
                        {
                            string _strEstadoEnvio = string.Empty;
                            
                            <tr>
                                <td align="left" data-title="Cod.Proveedor :">@Env.CodProveedor</td>
                                <td align="left" data-title="Proveedor :">@Env.NomProveedor</td>
                                <td align="left" data-title="Matricula : ">@Env.Matricula</td>
                                <td align="left" data-title="Articulo : ">@Env.NombreArticulo</td>
                                <td align="left" data-title="Fecha Envio :">@Env.FechaEnvio.ToString()</td>
                                <td align="left" data-title="Hora Envio :"> @Env.HoraEnvio.ToString()</td>
                                <td align="left" data-title="Kilos Enviados :">@Env.KilosEnviados</td>
                                <td align="left" data-title="Neto :">@Env.PesoBascula</td>
                                @{
                                        string balsaG = string.Empty;
                                        string balsaP = string.Empty;
                            
                                    if (Env.BasculaG == true)
                                    {
                                        balsaG = "Si";
                                        balsaP = "No";
                                
                                    }
                                    else
                                    {
                                        balsaG = "No";
                                        balsaP = "Si";
                                    }
                                }
                                <td align="left" data-title="Bascula Grande :">@balsaG</td>
                                <td align="left" data-title="Bascula Pequeña :">@balsaP</td>
                                <td align="left" data-title="Observaciones :">Env.Observaciones</td>
                                @{

                                    switch (Env.EstadoEnvio)
                                    {
                                        case 1:
                                            _strEstadoEnvio = "Enviado";
                                            break;
                                        case 2:
                                            _strEstadoEnvio = "En Bascula";
                                            break;
                                        case 3:
                                            _strEstadoEnvio = "Pesado";
                                            break;
                                    }

                                }
                                <td align="left" data-title="Estado">@_strEstadoEnvio</td>
                                <td align="left" data-title="Acciones :">
                                        @*<a href="javascript:void(0);" class="btnEdit" id="@Env.id"><i class="fa fa-pencil" aria-hidden="true"></i></a>
                                        <a href="javascript:void(0);" class="btnDelete" id="@Env.id"><i class="fa fa-times" aria-hidden="true"></i></a>*@
                                        <a href="javascript:void(0);" class="btnView" id="@Env.id"><i class="fa fa-eye" aria-hidden="true"></i></a>
                                    </td>
                            </tr>
                            acumulador += Convert.ToDecimal(Env.KilosEnviados);
                        }
                    </tbody>
                </table>
            </section>
            <hr />
            <div class="row col-md-offset-4" style="padding-right:40px">
                <div style="text-align:right">
                    <p><h3>Total Kilos: @acumulador</h3></p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center"><h3>No se ha encontrado resultados.</h3></div>
    }
</div>
<div class="row text-center mg-25">
    <div class="form-horizontal form-group">
        <!-- Button -->
        <div class="col-sm-12 controls log-sec">
            <input type="button" value="Volver a Consultar" id="btnAdd" class="btn btn-success btn-paysheetreviewrequest" />
        </div>
    </div>
</div>
